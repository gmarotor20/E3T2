<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="20" style="-fx-background-color: #f5f5f5; -fx-padding: 20;"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="eskaera.EskaeraKontrolagailua">

    <Text text="EROSKETAK" strokeType="OUTSIDE" strokeWidth="0.0" fill="#2c3e50">
        <font><Font name="System Bold" size="20.0"/></font>
    </Text>

    <Separator/>

    <TableView fx:id="tableView" prefHeight="400.0" prefWidth="900.0">
        <columns>
            <TableColumn fx:id="erosketaIdColumn" text="EROSKETA ID" prefWidth="100"/>
            <TableColumn fx:id="bezeroaColumn" text="BEZEROA" prefWidth="130"/>
            <TableColumn fx:id="produktuakColumn" text="PRODUKTUAK" prefWidth="300"/>
            <TableColumn fx:id="totalColumn" text="TOTAL (€)" prefWidth="100"/>
            <TableColumn fx:id="ordainketaMetodoaColumn" text="ORDAINKETA" prefWidth="100"/>
            <TableColumn fx:id="dataColumn" text="DATA" prefWidth="150"/>
        </columns>
    </TableView>

    <HBox alignment="CENTER_RIGHT">
        <Button fx:id="itzuliButton" text="ITZULI"
                style="-fx-background-color: #f39c12; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 5;"/>
    </HBox>

</VBox>