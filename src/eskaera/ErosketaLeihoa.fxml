<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="15" prefWidth="650" prefHeight="500" xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="eskaera.ErosketaLeihoaKontrolagailua"
      style="-fx-background-color: #f5f5f5; -fx-padding: 20;">

    <Label text="EROSKETAREN XEHETASUNAK" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;">
        <font><Font size="18"/></font>
    </Label>

    <Separator/>

    <GridPane hgap="15" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="120" prefWidth="140"/>
            <ColumnConstraints minWidth="200" prefWidth="400"/>
        </columnConstraints>

        <Label text="Erosketa ID:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="erosketaIdLabel" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Bezeroa:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
        <Label fx:id="bezeroaLabel" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Produktuak:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;"/>
        <TextArea fx:id="produktuakArea" GridPane.columnIndex="1" GridPane.rowIndex="2" editable="false" 
                  wrapText="true" prefHeight="150" prefWidth="400" style="-fx-font-size: 13px; -fx-background-color: white;"/>

        <Label text="Total:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold;"/>
        <Label fx:id="totalLabel" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Label text="Ordainketa Metodoa:" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-font-weight: bold;"/>
        <Label fx:id="ordainketaMetodoaLabel" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

        <Label text="Data:" GridPane.columnIndex="0" GridPane.rowIndex="5" style="-fx-font-weight: bold;"/>
        <Label fx:id="dataLabel" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
    </GridPane>

    <Separator/>

    <HBox alignment="CENTER">
        <Button fx:id="itxiButton" text="ITXI" onAction="#itxi"
                style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 20;"/>
    </HBox>

</VBox>