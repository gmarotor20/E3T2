<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="15" style="-fx-background-color: #f5f5f5; -fx-padding: 20;"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="denda.DendaKontrolagailua">

    <Text text="DENDA" strokeType="OUTSIDE" strokeWidth="0.0" fill="#2c3e50">
        <font><Font name="System Bold" size="20.0"/></font>
    </Text>

    <Separator/>

    <Label text="Produktuak:" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
    <TableView fx:id="produktuakTable" prefHeight="220.0" prefWidth="750.0">
        <columns>
            <TableColumn fx:id="izenaColumn" text="PRODUKTUA" prefWidth="370"/>
            <TableColumn fx:id="stockColumn" text="STOCK" prefWidth="100"/>
            <TableColumn fx:id="prezioaColumn" text="PREZIOA (€)" prefWidth="120"/>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Kantitatea:" style="-fx-font-weight: bold;"/>
        <Spinner fx:id="kantitateaSpinner" prefWidth="80"/>
        <Button text="GEHITU ORGATXORA"
                style="-fx-background-color: #3498db; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 5;"
                onAction="#gehituKarritora"/>
    </HBox>

    <Separator/>

    <Label text="Orgatxoa:" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
    <TableView fx:id="karritoTable" prefHeight="130.0" prefWidth="750.0">
        <columns>
            <TableColumn fx:id="karritoProduktuColumn" text="PRODUKTUA" prefWidth="370"/>
            <TableColumn fx:id="karritoKantitateaColumn" text="KANTITATEA" prefWidth="100"/>
            <TableColumn fx:id="karritoPrezioanColumn" text="PREZIOA (€)" prefWidth="120"/>
            <TableColumn fx:id="karritoTotalaColumn" text="TOTALA (€)" prefWidth="120"/>
        </columns>
    </TableView>

    <HBox spacing="20" alignment="CENTER_RIGHT">
        <Label fx:id="totalLabel" text="TOTALA: 0.00 €"
               style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #2c3e50;"/>
        <Button text="ORGATXOA GARBITU"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 5;"
                onAction="#garbituKarritoa"/>
        <Button text="ORDAINDU"
                style="-fx-background-color: #27ae60; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 5;"
                onAction="#ordaindu"/>
        <Button text="ITZULI"
                style="-fx-background-color: #f39c12; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 5;"
                onAction="#itzuli"/>
    </HBox>

</VBox>