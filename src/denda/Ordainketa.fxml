<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="15" style="-fx-background-color: #f5f5f5; -fx-padding: 20;"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="denda.OrdainketaKontrolagailua">

    <Text text="ORDAINKETA" strokeType="OUTSIDE" strokeWidth="0.0" fill="#2c3e50">
        <font><Font name="System Bold" size="20.0"/></font>
    </Text>

    <Separator/>

    <Label text="Zure eskaeraren laburpena:"
           style="-fx-font-weight: bold; -fx-font-size: 14px;"/>

    <TableView fx:id="laburpenaTable" prefHeight="200.0" prefWidth="500.0">
        <columns>
            <TableColumn fx:id="produktuaColumn" text="PRODUKTUA" prefWidth="250"/>
            <TableColumn fx:id="kantitateaColumn" text="KANTITATEA" prefWidth="100"/>
            <TableColumn fx:id="totalaColumn" text="TOTALA (€)" prefWidth="120"/>
        </columns>
    </TableView>

    <Label fx:id="totalLabel" text="TOTALA: 0.00 €"
           style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #27ae60;"/>

    <Separator/>

    <Label text="Ordainketa metodoa hautatu:"
           style="-fx-font-weight: bold; -fx-font-size: 14px;"/>

    <ComboBox fx:id="ordainketaComboBox" prefWidth="250"
              promptText="Hautatu ordainketa metodoa..."/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="BERTAN BEHERA"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 5;"
                onAction="#bertanBehera"/>
        <Button text="ORDAINKETA BAIEZTATU"
                style="-fx-background-color: #27ae60; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 5;"
                onAction="#baieztatuOrdainketa"/>
    </HBox>

</VBox>