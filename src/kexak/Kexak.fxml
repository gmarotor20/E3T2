<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="20" style="-fx-background-color: #f5f5f5; -fx-padding: 20;"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="kexak.KexakKontrolagailua">

    <Text text="BEZEROEN KEXAK" strokeType="OUTSIDE" strokeWidth="0.0" fill="#2c3e50">
        <font><Font name="System Bold" size="20.0"/></font>
    </Text>

    <Separator/>

    <TableView fx:id="tableView" prefHeight="400.0" prefWidth="950.0">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="50"/>
            <TableColumn fx:id="bezeroaColumn" text="Bezeroa" prefWidth="150"/>
            <TableColumn fx:id="emailaColumn" text="Emaila" prefWidth="160"/>
            <TableColumn fx:id="motiboarenColumn" text="Motiboa" prefWidth="100"/>
            <TableColumn fx:id="mezuaColumn" text="Mezua" prefWidth="240"/>
            <TableColumn fx:id="dataColumn" text="Data" prefWidth="150"/>
            <TableColumn fx:id="egoeraColumn" text="Egoera" prefWidth="90"/>
        </columns>
    </TableView>

    <HBox alignment="CENTER_RIGHT">
        <Button fx:id="itzuliButton" text="ITZULI"
                style="-fx-background-color: #f39c12; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 5;"/>
    </HBox>

</VBox>