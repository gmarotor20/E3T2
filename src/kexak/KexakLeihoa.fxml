<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="15" xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="kexak.KexakLeihoaKontrolagailua"
      style="-fx-background-color: #f5f5f5; -fx-padding: 20;">

    <Label text="KEXAREN XEHETASUNAK" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;">
        <font><Font size="18"/></font>
    </Label>

    <Separator/>

    <GridPane hgap="15" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="80" prefWidth="100"/>
            <ColumnConstraints minWidth="200" prefWidth="300"/>
        </columnConstraints>

        <Label text="Bezeroa:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="bezeroaLabel" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Emaila:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
        <Label fx:id="emailaLabel" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Motiboa:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;"/>
        <Label fx:id="motiboaLabel" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="Data:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold;"/>
        <Label fx:id="dataLabel" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Label text="Egoera:" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-font-weight: bold;"/>
        <Label fx:id="egoeraLabel" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

        <Label text="Mezua:" GridPane.columnIndex="0" GridPane.rowIndex="5" style="-fx-font-weight: bold;"/>
    </GridPane>

    <TextArea fx:id="mezuaArea" editable="false" wrapText="true" prefHeight="150"
              style="-fx-background-color: white; -fx-font-size: 13px;"/>

    <Separator/>

    <HBox alignment="CENTER">
        <Button fx:id="itxiButton" text="ITXI" onAction="#itxi"
                style="-fx-background-color: #f39c12; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 5;
                       -fx-padding: 8 20;"/>
    </HBox>

</VBox>